# SmartKhata frontend — copy to .env.local for local overrides

# Empty in dev: Vite proxies /api → backend; axios calls use relative /api/v1/...
# Production: your deployed API origin ONLY (no trailing slash), e.g. https://smartkhata-api.onrender.com
VITE_API_URL=

# Backwards-compatible alias if you already use this name
# VITE_API_BASE_URL=

# Optional: override dev proxy target (vite.config.js)
# API_PROXY_TARGET=http://127.0.0.1:5000
